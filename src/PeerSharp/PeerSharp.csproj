<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<WarningsAsErrors>CS8600;CS8602;CS8603;CS8604;CS8618;CS8620;CS8625;CS8655;CS8669</WarningsAsErrors>
		<Authors>Peerfluence</Authors>
		<Copyright>Copyright (c) 2026 ligenq</Copyright>
		<Description>A high-performance BitTorrent engine for .NET.</Description>
		<PackageTags>bittorrent;torrent;p2p;peer-to-peer;dht;magnet;utp;streaming;download</PackageTags>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<PackageProjectUrl>https://github.com/ligenq/PeerSharp</PackageProjectUrl>
		<RepositoryUrl>https://github.com/ligenq/PeerSharp</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageIcon>application-icon.png</PackageIcon>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageReleaseNotes>New magnet APIs: preview a magnet's file list before downloading (GetMagnetMetadataAsync, AddTorrentOptions.StopAfterMetadata, ITorrent.WaitForMetadataAsync) and export/cache metadata to skip re-downloading it (ITorrent.ExportTorrentFile). BEP 53: magnet URI file selection (so=). BEP 47: full support for file attributes, symlinks, and per-file SHA-1 in v1/v2/hybrid torrents. Storage reliability: write/read failures now surface instead of being swallowed - disk-full or a permanently failed file stops the torrent with an error instead of re-downloading pieces forever or serving zero-filled data that gets the client banned. Duplicate peer connections are deduplicated by endpoint and peer id, and failed handshakes close the incomplete peer. Hardening: UDP receive-loop backoff on persistent socket errors, uTP connect cancellation fixes, NAT-PMP receive timeout fix, PeerManager decomposition, and eight correctness/security fixes across DHT, blocklist, cache, and trackers.</PackageReleaseNotes>
		<IsTrimmable>true</IsTrimmable>
	</PropertyGroup>

	<ItemGroup>
		<None Include="application-icon.png" Pack="true" PackagePath="\" />
		<None Include="..\..\README.md" Pack="true" PackagePath="\" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.10" />
		<PackageReference Include="SonarAnalyzer.CSharp" Version="10.29.0.143774">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
	</ItemGroup>

	<ItemGroup>
		<Compile Remove="Types\**\*.cs" />
		<Compile Remove="Internals\Utilities\Bencode\**\*.cs" />
		<Compile Remove="Internals\Peers\MessageId.cs" />
		<Compile Remove="Internals\Peers\PeerMessage.cs" />
		<Compile Remove="Internals\Pieces\PiecePicker.cs" />
		<Compile Remove="Internals\Pieces\IPiecePickerContext.cs" />
		<Compile Remove="Internals\Pieces\PiecesProgress.cs" />
		<Compile Remove="Internals\Pieces\PieceChecker.cs" />
		<Compile Remove="Internals\Pieces\Block.cs" />
		<Compile Remove="Internals\IO\**\*.cs" />
		<Compile Remove="Internals\Streaming\**\*.cs" />
	</ItemGroup>

	<ItemGroup>
		<AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
			<_Parameter1>PeerSharp.Tests</_Parameter1>
		</AssemblyAttribute>
	</ItemGroup>

</Project>
