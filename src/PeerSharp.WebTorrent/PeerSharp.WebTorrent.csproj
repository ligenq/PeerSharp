<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<WarningsAsErrors>CS8600;CS8602;CS8603;CS8604;CS8618;CS8620;CS8625;CS8655;CS8669</WarningsAsErrors>
		<Authors>Peerfluence</Authors>
		<Copyright>Copyright (c) 2026 ligenq</Copyright>
		<Description>Optional WebTorrent over WebRTC support for PeerSharp.</Description>
		<PackageTags>bittorrent;torrent;p2p;peer-to-peer;webtorrent;webrtc</PackageTags>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<PackageProjectUrl>https://github.com/ligenq/PeerSharp</PackageProjectUrl>
		<RepositoryUrl>https://github.com/ligenq/PeerSharp</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageIcon>application-icon.png</PackageIcon>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageReleaseNotes>Fix false-positive "Error attaching data channel" log entries that fired whenever a pending peer was disposed before its data channel opened. Pending peers now have a lifetime cancellation source that is signaled on teardown so background waits classify the cancellation as expected instead of error.</PackageReleaseNotes>
		<IsTrimmable>true</IsTrimmable>
		<RootNamespace>PeerSharp.WebTorrent</RootNamespace>
		<AssemblyName>PeerSharp.WebTorrent</AssemblyName>
	</PropertyGroup>

	<ItemGroup>
		<None Include="..\PeerSharp\application-icon.png" Pack="true" PackagePath="\" />
		<None Include="..\..\README.md" Pack="true" PackagePath="\" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\PeerSharp\PeerSharp.csproj" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.7" />
		<PackageReference Include="RtcForge" Version="1.0.0" />
		<PackageReference Include="SonarAnalyzer.CSharp" Version="10.24.0.138807">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
	</ItemGroup>

	<ItemGroup>
		<AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
			<_Parameter1>PeerSharp.WebTorrent.Tests</_Parameter1>
		</AssemblyAttribute>
	</ItemGroup>

</Project>
